# Root homelab environment template. Copy to .env and fill real values locally.
# Keep this file secret-free: placeholders only.

# =============================================================================
# Active stack variables
# =============================================================================

# Traefik / Cloudflare
CF_API_EMAIL=you@example.com

# Plex
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# Karakeep
KARAKEEP_VERSION=release
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=https://karakeep.docker.local.example
MEILI_MASTER_KEY=change-me-at-least-16-bytes
GEMINI_API_KEY=change-me

# Freedium
ADMIN_SECRET_KEY=change-me
FREEDIUM_POSTGRES_PASSWORD=change-me

# Movie Tracker
MT_LOG_LEVEL=INFO
MT_TG_BOT_API_KEY=change-me
MT_TG_BOT_CHAT_IDS=123456789
MT_QBITTORRENT_URL=http://gluetun:8400
MT_QBITTORRENT_USERNAME=
MT_QBITTORRENT_PASSWORD=
MT_PROWLARR_URL=http://gluetun:9696
MT_PROWLARR_API_KEY=change-me
MT_TMDB_API_KEY=change-me
MT_TMDB_LANGUAGE=ru
MT_DATABASE_URL=sqlite:///./app.db

# =============================================================================
# Inactive or optional service templates
# =============================================================================
# These values are kept for services that are currently disabled, commented out,
# or configured through service-local env_file entries. Fill them only when
# enabling the corresponding service.

# Gotify / notifications (inactive)
GOTIFY_CLIENT_TOKENS=change-me
SECNTFY_TOKENS=change-me

# Pritunl / wproxy (inactive)
PRITUNL_PIN_CODE=change-me
PRITUNL_SECRET_CODE=change-me

# MSSQL (inactive)
SA_PASSWORD=change-me-strong-password
MSSQL_DATABASE=app

# Miniflux (inactive)
MINIFLUX_POSTGRES_USER=miniflux
MINIFLUX_POSTGRES_PASSWORD=change-me
MINIFLUX_POSTGRES_DB=miniflux
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=change-me

# Glance / Speedtest Tracker convenience values (service-local env_file users)
SPEEDTEST_URL=https://speedtest.docker.local.example
SPEEDTEST_TRACKER_API_TOKEN=change-me

# Speedtest Tracker service-local .env example values
APP_KEY=base64:change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
