# Root homelab environment template. Copy to .env and fill real values locally.
# Keep this file secret-free: placeholders only.

# =============================================================================
# Active stack variables
# =============================================================================

# Public-safe host and path defaults. Override these in the real local `.env`.
DOCKER_DOMAIN=docker.local.example
LAN_DOMAIN=local.example
HOMELAB_ROOT=/opt/homelab
INTERNAL_STORAGE=/mnt/internal
USB_STORAGE=/mnt/usb_drive
PLEX_ORPHAN_WATCHER_IMAGE=ghcr.io/iamstubborn/plex-orphan-watcher:0.2.0@sha256:7bff06ada86ae36459fbdf55398316fd93e402ed758891c09a0f959ef70a216d
TIMEZONE=UTC
LAN_BIND_IP=127.0.0.1
LAN_SUBNET=192.0.2.0/24
ALT_LAN_SUBNET=198.51.100.0/24
DNS_ADDRESS=192.0.2.1
ALT_DNS_ADDRESS=198.51.100.1
OLLAMA_HOST_IP=127.0.0.1
WEATHER_LOCATION=London, United Kingdom

# Traefik / Cloudflare
CF_API_EMAIL=you@example.com

# Plex
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# Media orchestrator scaffold (inactive until its dedicated Compose profile is used)
# Pin every image to a release tag plus digest before enabling the stack.
MEDIA_POSTGRES_IMAGE=postgres:17.5-alpine@sha256:replace-with-real-digest
MEDIA_SERVICE_IMAGE=ghcr.io/your-org/media-orchestrator:0.1.0@sha256:replace-with-real-digest
DOWNLOAD_RUNNER_IMAGE=ghcr.io/your-org/media-orchestrator:0.1.0@sha256:replace-with-real-digest
GLUETUN_REZKA_IMAGE=qmcgaw/gluetun:v3.41.1@sha256:replace-with-real-digest
GLUETUN_REZKA_WATCHER_IMAGE=docker:28.3.2-cli@sha256:replace-with-real-digest
MEDIA_SECRETS_DIR=/opt/homelab/media/secrets
MEDIA_POSTGRES_DB=media_orchestrator
MEDIA_POSTGRES_USER=media
MEDIA_POSTGRES_PASSWORD=change-me
MEDIA_DATABASE_URL=postgres://media:change-me@media-postgres:5432/media_orchestrator
MEDIA_ANDRII_TOKEN=change-me
MEDIA_VALENTYNA_TOKEN=change-me
MEDIA_RUNNER_TOKEN=change-me
MEDIA_ANDRII_WEBHOOK_HMAC=change-me
MEDIA_VALENTYNA_WEBHOOK_HMAC=change-me
MEDIA_NETWORK=media-internal
MEDIA_PROWLARR_API_KEY=change-me
MEDIA_PLEX_TOKEN=change-me
MEDIA_PLEX_TV_SECTION=replace-with-tv-section-id
MEDIA_PLEX_MOVIES_SECTION=replace-with-movies-section-id
MEDIA_QBITTORRENT_TV_CATEGORY=tv
MEDIA_QBITTORRENT_MOVIES_CATEGORY=movies
MEDIA_QBITTORRENT_USERNAME=replace-with-username
MEDIA_QBITTORRENT_PASSWORD=change-me
GLUETUN_REZKA_SERVER_COUNTRIES=Bulgaria
GLUETUN_REZKA_CONTROL_API_KEY=change-me
MEDIA_REZKA_MIRRORS=https://rezka.example
MEDIA_REZKA_SESSION_PROBE_URL=https://rezka.example/account/probe
MEDIA_REZKA_SESSION_VALID_MARKERS_JSON=["account-menu"]
MEDIA_REZKA_SESSION_INVALID_MARKERS_JSON=["login-form"]
MEDIA_REZKA_USERNAME=replace-with-username
MEDIA_REZKA_PASSWORD=change-me
ANDRII_REZKA_BROKER_TOKEN=change-me
MEDIA_REZKA_COOKIE_KEY=replace-with-base64-encoded-32-byte-key
MEDIA_RUST_LOG=info
RENDER_GID=109
VIDEO_GID=44

# Karakeep
KARAKEEP_VERSION=release
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=https://karakeep.${DOCKER_DOMAIN}
MEILI_MASTER_KEY=change-me-at-least-16-bytes
GEMINI_API_KEY=change-me
KARAKEEP_CRAWLER_ALLOWED_INTERNAL_HOSTNAMES=freedium.${DOCKER_DOMAIN}

# Freedium
ADMIN_SECRET_KEY=change-me
FREEDIUM_POSTGRES_PASSWORD=change-me
FREEDIUM_DATABASE_URL=postgresql://postgres:change-me@freedium-db:5432/postgres

# Movie Tracker
MT_LOG_LEVEL=INFO
MT_TG_BOT_API_KEY=change-me
MT_TG_BOT_CHAT_IDS=123456789
MT_QBITTORRENT_URL=http://gluetun:8400
MT_QBITTORRENT_USERNAME=
MT_QBITTORRENT_PASSWORD=
MT_PROWLARR_URL=http://gluetun:9696
MT_PROWLARR_API_KEY=change-me
MT_TMDB_API_KEY=change-me
MT_TMDB_LANGUAGE=ru
MT_DATABASE_URL=sqlite:///./app.db

# =============================================================================
# Inactive or optional service templates
# =============================================================================
# These values are kept for services that are currently disabled, commented out,
# or configured through service-local env_file entries. Fill them only when
# enabling the corresponding service.

# Gotify / notifications (inactive)
GOTIFY_CLIENT_TOKENS=change-me
SECNTFY_TOKENS=change-me

# Pritunl / wproxy (inactive)
PRITUNL_PIN_CODE=change-me
PRITUNL_SECRET_CODE=change-me

# MSSQL (inactive)
SA_PASSWORD=change-me-strong-password
MSSQL_DATABASE=app

# Miniflux (inactive)
MINIFLUX_POSTGRES_USER=miniflux
MINIFLUX_POSTGRES_PASSWORD=change-me
MINIFLUX_POSTGRES_DB=miniflux
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=change-me

# Glance / Speedtest Tracker convenience values (service-local env_file users)
SPEEDTEST_URL=https://speedtest.${DOCKER_DOMAIN}
SPEEDTEST_TRACKER_API_TOKEN=change-me

# Speedtest Tracker service-local .env example values
APP_KEY=base64:change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
