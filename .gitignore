# IDE/local agent state
.DS_Store
**/.DS_Store
.idea/
**/.idea/
**/.vscode/settings.json
.cursor/
**/.cursor/
.claude/settings.local.json
**/.claude/settings.local.json

# Service-specific runtime folders with only compose/config tracked
ai/ollama/
ai/ollama-webui/
!ai/compose.yml
wproxy/pritunl/profiles/

# Embedded repositories / vendored source trees: track via submodules or their own repos.
media/qbittorrent/ui/VueTorrent/

# VPN/exported bundles and mutable app state
wproxy/backup.ovpn
wproxy/pritunl/config.tar
zeroclaw/config/auth-profiles.json
zeroclaw/config/daemon_state.json

# Real service configs containing secrets; keep sanitized examples instead
samba/config/config.yml
glance/config/glance.yml
traefik/config/config.yml
homeassistant/config/configuration.yaml
homeassistant/config/automations.yaml
homeassistant/config/scripts.yaml
homeassistant/config/scenes.yaml
homeassistant/config/.HA_VERSION
homeassistant/config/.ha_run.lock

# Local scratch files and agent/tooling state that should never be part of the backup repo
notes.txt
package-lock.json
package.json
.claude/

# Top-level service folders not included by root compose.yml
ai/
bytebase/
filebrowser/
gotify/
miniflux/
mssql/
portainer/
wproxy/
zeroclaw/

# movie-tracker is included by root compose; track only its compose wrapper, not app source
!movie-tracker/
movie-tracker/**
!movie-tracker/docker-compose.yml
