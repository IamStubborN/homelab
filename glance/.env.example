SPEEDTEST_URL=https://speedtest.docker.local.example
SPEEDTEST_VPN_URL=http://gluetun
SPEEDTEST_VPN_PUBLIC_URL=https://speedtest-vpn.docker.local.example
GLUETUN_CONTROL_URL=http://gluetun:8000
# Must equal the apikey in media/secrets/gluetun_control_auth_config
# (and media/secrets/gluetun_control_api_key). Generate with:
#   docker run --rm qmcgaw/gluetun:<pinned-version> genkey
GLUETUN_CONTROL_API_KEY=change-me
SPEEDTEST_TRACKER_API_TOKEN=change-me
# Same value as one of the media-orchestrator family client tokens
# (media_andrii_token or media_valentyna_token) — see media/README.md.
MEDIA_STATUS_TOKEN=change-me
DOCKER_DOMAIN=docker.local.example
LAN_DOMAIN=local.example
WEATHER_LOCATION=Varna, Bulgaria
